# macOS
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \\r
Icon\r\n

# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
ENV/
env/

# IDEs / editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Distribution / packaging
*.egg-info/
*.egg
build/
dist/
*.whl

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Streamlit
.streamlit/

# Logs
logs/
*.log

# Model artifacts / data artifacts (optional)
gesture_model.pkl
model_1hand.pkl
gesture_dataset.csv
dataset/

